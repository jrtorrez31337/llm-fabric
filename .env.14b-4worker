# SSW AI Inference — Qwen3-14B AWQ, 4 workers (2 per GPU)
#
# Usage:
#   docker compose -p sswai -f docker-compose.14b-4worker.yml --env-file .env.14b-4worker up -d
#
# VRAM layout per GPU (48GB A40):
#   Instance A: 0.46 × 48GB = 22.1GB  →  ~10.5GB weights + ~11.6GB KV cache
#   Instance B: 0.46 × 48GB = 22.1GB  →  ~10.5GB weights + ~11.6GB KV cache
#   Total: 44.2GB used, 3.8GB CUDA overhead
#
# KV cache at 40K context (40 layers, 8 KV heads, head_dim=128, fp16):
#   ~160KB per token → ~6.4GB per full 40K sequence
#   Practical concurrency: ~4-5 sequences at 15K avg tokens per worker

# === Model ===
MODEL_REPO=/data/models
PRIMARY_MODEL=Qwen/Qwen3-14B-AWQ
FOURWORKER_MODELS_YAML_PATH=./gateway/models.14b-4worker.yaml

# === vLLM Settings ===
# YaRN rope scaling: factor 1.2 × native 40,960 = 49,152 (48K) max context.
# Scaling arg is baked into the compose command list.
PRIMARY_GPU_MEMORY_UTILIZATION=0.46
VLLM_MAX_MODEL_LEN=49152
VLLM_MAX_NUM_SEQS=32
VLLM_MAX_NUM_BATCHED_TOKENS=16384
VLLM_TOOL_CALL_PARSER=hermes
PRIMARY_DTYPE=half
PRIMARY_QUANTIZATION=awq_marlin

# === Worker Ports ===
MODEL_0_PORT=8001
MODEL_1_PORT=8002
MODEL_2_PORT=8003
MODEL_3_PORT=8004

# === Redis ===
REDIS_PORT=6379

# === Gateway ===
GATEWAY_PORT=8000

# === Loader ===
LOADER_PORT=8011
LOADER_DOCKER_NETWORK=sswai_default
LOADER_CONTAINER_PREFIX=ssw
