# SSW AI — 3-Tier Config (Config I)
#
# Heavy (GPU 1, dedicated): Qwen3.5-27B dense — premium reasoning
# Light (GPU 0, 2 workers): Qwen3-30B-A3B MoE — general purpose
# Fast  (GPU 0 + masheen):  Same 2 MoE workers + masheen 4B = 3 workers

# Heavy worker (GPU 1) — Qwen3.5-27B dense, dedicated GPU
HEAVY_MODEL=cyankiwi/Qwen3.5-27B-AWQ-4bit
HEAVY_GPU_MEMORY_UTILIZATION=0.90
HEAVY_DTYPE=half
HEAVY_QUANTIZATION=compressed-tensors
HEAVY_MAX_MODEL_LEN=65536
HEAVY_MAX_NUM_SEQS=32
HEAVY_MAX_NUM_BATCHED_TOKENS=16384
HEAVY_TOOL_CALL_PARSER=qwen3_coder

# Light worker (GPU 0, single) — 30B MoE, also serves fast
LIGHT_MODEL=stelterlab/Qwen3-30B-A3B-Instruct-2507-AWQ
LIGHT_GPU_MEMORY_UTILIZATION=0.90
LIGHT_DTYPE=half
LIGHT_QUANTIZATION=compressed-tensors
LIGHT_MAX_MODEL_LEN=65536
LIGHT_MAX_NUM_SEQS=32
LIGHT_MAX_NUM_BATCHED_TOKENS=32768
LIGHT_TOOL_CALL_PARSER=hermes

MODEL_REPO=/data/models
GATEWAY_PORT=8000
LOADER_PORT=8011
REDIS_PORT=6379

LOADER_DOCKER_NETWORK=sswai_default
LOADER_CONTAINER_PREFIX=ssw
