# SSW AI — Config J (Capacity Mode)
#
# GPU 0 (light-0): 30B MoE AWQ, 65K context — light pool
# GPU 1 (light-1): 30B MoE AWQ, 262K context — light + heavy pools
# Masheen: 4B AWQ, 16K context — fast pool

MOE_MODEL=stelterlab/Qwen3-30B-A3B-Instruct-2507-AWQ
MOE_GPU_MEMORY_UTILIZATION=0.90
MOE_DTYPE=half
MOE_QUANTIZATION=compressed-tensors
MOE_MAX_NUM_SEQS=32
MOE_MAX_NUM_BATCHED_TOKENS=32768
MOE_TOOL_CALL_PARSER=hermes

# Per-GPU context limits
MOE_MAX_MODEL_LEN_0=65536
MOE_MAX_MODEL_LEN_1=262144

MODEL_REPO=/data/models
GATEWAY_PORT=8000
REDIS_PORT=6379
