# SSW AI — Masheen (RTX 2080 8GB), Qwen3-4B-AWQ, 1 worker
PRIMARY_MODEL=Qwen/Qwen3-4B-AWQ
PRIMARY_GPU_MEMORY_UTILIZATION=0.80
PRIMARY_DTYPE=half
PRIMARY_QUANTIZATION=awq_marlin

VLLM_MAX_MODEL_LEN=16384
VLLM_MAX_NUM_SEQS=32
VLLM_MAX_NUM_BATCHED_TOKENS=8192
VLLM_TOOL_CALL_PARSER=hermes

MODEL_REPO=/data/models
MODEL_0_PORT=8001
GATEWAY_PORT=8000
LOADER_PORT=8011
REDIS_PORT=6379

LOADER_DOCKER_NETWORK=sswai_default
LOADER_CONTAINER_PREFIX=ssw-masheen
