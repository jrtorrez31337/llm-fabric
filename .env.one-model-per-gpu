# SSW AI Inference — One model per GPU profile
#
# Usage:
#   docker compose -f docker-compose.one-model-per-gpu.yml --env-file .env.one-model-per-gpu up -d

# === Model Paths ===
MODEL_REPO=/data/models

# Recommended baseline for 32K + high agent count:
# - 4B AWQ keeps throughput high
# - this 2507 variant supports very long context in model config
PRIMARY_MODEL=Qwen/Qwen3-4B-Instruct-2507-AWQ
ONE_MODEL_MODELS_YAML_PATH=./gateway/models.one-model-per-gpu.yaml

# === vLLM Settings ===
PRIMARY_GPU_MEMORY_UTILIZATION=0.90
VLLM_MAX_MODEL_LEN=32768
VLLM_MAX_NUM_SEQS=64
VLLM_MAX_NUM_BATCHED_TOKENS=65536
VLLM_TOOL_CALL_PARSER=hermes
PRIMARY_DTYPE=half
PRIMARY_QUANTIZATION=awq_marlin

# === Worker Ports ===
MODEL_0_PORT=8001
MODEL_1_PORT=8002

# === Redis ===
REDIS_PORT=6379

# === Gateway ===
GATEWAY_PORT=8000

# === Loader ===
LOADER_PORT=8011
LOADER_DOCKER_NETWORK=sswai_default
LOADER_CONTAINER_PREFIX=ssw
