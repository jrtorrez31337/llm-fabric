# SSW AI — Qwen3-30B-A3B MoE AWQ, 1 worker per GPU
PRIMARY_MODEL=stelterlab/Qwen3-30B-A3B-Instruct-2507-AWQ
PRIMARY_GPU_MEMORY_UTILIZATION=0.90
PRIMARY_DTYPE=half
PRIMARY_QUANTIZATION=compressed-tensors

VLLM_MAX_MODEL_LEN=49152
VLLM_MAX_NUM_SEQS=64
VLLM_MAX_NUM_BATCHED_TOKENS=32768
VLLM_TOOL_CALL_PARSER=hermes

MODEL_REPO=/data/models
MODEL_0_PORT=8001
MODEL_1_PORT=8002
GATEWAY_PORT=8000
LOADER_PORT=8011
REDIS_PORT=6379

LOADER_DOCKER_NETWORK=sswai_default
LOADER_CONTAINER_PREFIX=ssw
